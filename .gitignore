# Python
__pycache__/
*.pyc
.ipynb_checkpoints/

# Large/generated experiment artifacts
*.pkl
*.pickle
*.npy
*.npz
*.bin
*.pt
*.pth
*.ckpt
*.faiss
*.index

# Local benchmark datasets
sybaek/datasets/webtable_join/*
!sybaek/datasets/webtable_join/README.md

# Sybaek local DeepJoin failure-analysis artifacts
sybaek/failure_analysis/deepjoin/artifacts/*
!sybaek/failure_analysis/deepjoin/artifacts/.gitkeep
sybaek/failure_analysis/deepjoin/cache/*
!sybaek/failure_analysis/deepjoin/cache/.gitkeep
sybaek/failure_analysis/deepjoin/logs/*
!sybaek/failure_analysis/deepjoin/logs/.gitkeep

# Reproducible DeepJoin failure-analysis outputs
sybaek/failure_analysis/deepjoin/results/*
!sybaek/failure_analysis/deepjoin/results/.gitkeep
!sybaek/failure_analysis/deepjoin/results/failure_group_summary.csv
!sybaek/failure_analysis/deepjoin/results/webtable_join_prepare_summary.csv
!sybaek/failure_analysis/deepjoin/results/plots/
!sybaek/failure_analysis/deepjoin/results/plots/.gitkeep
!sybaek/failure_analysis/deepjoin/results/samples/
!sybaek/failure_analysis/deepjoin/results/samples/.gitkeep
